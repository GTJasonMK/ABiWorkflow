# LLM 配置（根据模型名自动检测 API 格式：含 claude 使用 Anthropic API，其余使用 OpenAI 兼容 API）
LLM_API_KEY=your-key-here
LLM_MODEL=gpt-4o
LLM_BASE_URL=
GGK_BASE_URL=
GGK_API_KEY=

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./abi_workflow.db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 视频生成
VIDEO_PROVIDER=mock
VIDEO_OUTPUT_DIR=./outputs/videos
COMPOSITION_OUTPUT_DIR=./outputs/compositions
VIDEO_PROVIDER_MAX_DURATION_SECONDS=6
VIDEO_POLL_INTERVAL_SECONDS=1
VIDEO_TASK_TIMEOUT_SECONDS=300
# 分镜资产沉淀：项目沉淀时默认是否同步发布到全局资产池
PROJECT_ASSET_PUBLISH_GLOBAL_DEFAULT=false

# 通用 HTTP 视频提供者配置（当 VIDEO_PROVIDER=http 时使用）
VIDEO_HTTP_BASE_URL=
VIDEO_HTTP_API_KEY=
VIDEO_HTTP_GENERATE_PATH=/v1/video/generations
VIDEO_HTTP_STATUS_PATH=/v1/video/generations/{task_id}
VIDEO_HTTP_TASK_ID_PATH=task_id
VIDEO_HTTP_STATUS_VALUE_PATH=status
VIDEO_HTTP_PROGRESS_PATH=progress_percent
VIDEO_HTTP_RESULT_URL_PATH=result_url
VIDEO_HTTP_ERROR_PATH=error_message
VIDEO_HTTP_REQUEST_TIMEOUT_SECONDS=60

# GGK 视频提供者配置（当 VIDEO_PROVIDER=ggk 时使用）
GGK_VIDEO_MODEL=grok-imagine-1.0-video
GGK_VIDEO_ASPECT_RATIO=16:9
GGK_VIDEO_RESOLUTION=SD
GGK_VIDEO_PRESET=normal
# 模型级时长策略（JSON 字符串，可选）
# 例如：
# {"grok-imagine-1.0-video":{"min_seconds":5,"max_seconds":15,"allowed_seconds":[5,6,8,10,15],"prompt_hint_template":"请将该镜头时长控制在约 {seconds} 秒，保证动作节奏完整。"}}
GGK_VIDEO_MODEL_DURATION_PROFILES=
GGK_REQUEST_TIMEOUT_SECONDS=300

# TTS
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 调试
DEBUG=true

# 角色立绘生成（OpenAI 兼容图片 API）
PORTRAIT_API_BASE_URL=
PORTRAIT_API_KEY=
PORTRAIT_IMAGE_MODEL=grok-imagine-1.0
PORTRAIT_OUTPUT_DIR=./outputs/portraits
PORTRAIT_REQUEST_TIMEOUT_SECONDS=120

# 默认模型绑定与模型能力配置（JSON 字符串）
# 例如：{"analysisModel":"gpt-4o","videoModel":"grok-imagine-1.0-video"}
DEFAULT_MODEL_BINDINGS={}
# 例如：{"grok-imagine-1.0-video":{"allowed_seconds":[5,8,10],"aspect_ratios":["16:9","9:16"]}}
MODEL_CAPABILITY_PROFILES={}
