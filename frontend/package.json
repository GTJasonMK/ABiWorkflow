{
  "name": "abi-workflow-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "desktop:dev": "node ./scripts/electron-dev.mjs",
    "desktop:start": "npm run build && electron .",
    "desktop:dist": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "antd": "^5.22.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.abiworkflow.desktop",
    "productName": "AbiWorkflow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
